  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <script src="/_sdk/element_sdk.js"></script>
  <script src="/_sdk/data_sdk.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&amp;family=Poppins:wght@400;600;700&amp;display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Poppins', sans-serif; }
    .title-font { font-family: 'Bebas Neue', sans-serif; }
    
    @keyframes scoreUp {
      0% { transform: scale(1); }
      50% { transform: scale(1.2); color: #22c55e; }
      100% { transform: scale(1); }
    }
    
    @keyframes scoreDown {
      0% { transform: scale(1); }
      50% { transform: scale(1.2); color: #ef4444; }
      100% { transform: scale(1); }
    }
    
    @keyframes pulse-glow {
      0%, 100% { box-shadow: 0 0 20px rgba(99, 102, 241, 0.4); }
      50% { box-shadow: 0 0 40px rgba(99, 102, 241, 0.8); }
    }
    
    .score-up { animation: scoreUp 0.5s ease-out; }
    .score-down { animation: scoreDown 0.5s ease-out; }
    .winner-glow { animation: pulse-glow 2s infinite; }
    
    .gradient-bg {
      background: linear-gradient(135deg, #1e1b4b 0%, #312e81 50%, #1e1b4b 100%);
    }
    
    .card-gradient {
      background: linear-gradient(180deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0.05) 100%);
    }
    
    .btn-plus {
      background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
    }
    
    .btn-minus {
      background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
    }
    
    .btn-custom {
      background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
    }

    .team-card {
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255,255,255,0.1);
    }

    .display-card {
      background: linear-gradient(180deg, rgba(99,102,241,0.2) 0%, rgba(99,102,241,0.05) 100%);
      border: 2px solid rgba(99,102,241,0.3);
    }

