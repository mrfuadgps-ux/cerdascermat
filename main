 <body class="h-full gradient-bg text-white overflow-auto"><!-- Landing Screen -->
  <div id="landing-screen" class="h-full flex flex-col items-center justify-center p-8"><img src="https://pelitaglobalmandiri.sch.id/wp-content/uploads/2025/05/cropped-LOGO-PGM-KOTAK.webp" alt="Logo" class="h-24 mb-8" loading="lazy" onerror="console.error('Logo failed to load:', this.src); this.style.display='none';">
   <div class="text-center max-w-2xl flex-1 flex flex-col items-center justify-center">
    <div class="mb-8">
     <h1 id="main-title" class="title-font text-6xl md:text-8xl text-white tracking-wider mb-4">CERDAS CERMAT</h1>
    </div>
    <div class="flex flex-col sm:flex-row gap-4 justify-center mt-12"><button onclick="openOperator()" class="px-8 py-4 bg-indigo-600 hover:bg-indigo-700 rounded-xl font-semibold text-lg transition-all transform hover:scale-105 flex items-center justify-center gap-3"> <span>⚙️</span> Panel Operator </button> <button onclick="openDisplay()" class="px-8 py-4 bg-emerald-600 hover:bg-emerald-700 rounded-xl font-semibold text-lg transition-all transform hover:scale-105 flex items-center justify-center gap-3"> <span>📺</span> Layar Peserta </button>
